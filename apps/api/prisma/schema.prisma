// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPERVISOR
  OPERATOR
  READONLY
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum TransferStatus {
  IN_TRANSIT
  RECEIVED
}

enum PurchaseOrderStatus {
  PENDING
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ReservationStatus {
  ACTIVE
  DISPATCHED
  CANCELLED
  EXPIRED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  warehousePermissions   WarehousePermission[]
  stockMovements         StockMovement[]
  transfersCreated       Transfer[]            @relation("TransferCreatedBy")
  transfersReceived      Transfer[]            @relation("TransferReceivedBy")
  purchaseOrders         PurchaseOrder[]
  reservationsCreated    Reservation[]         @relation("ReservationCreatedBy")
  reservationsDispatched Reservation[]         @relation("ReservationDispatchedBy")
  cycleCountsCreated     CycleCount[]          @relation("CycleCountCreatedBy")
  cycleCountsCommitted   CycleCount[]          @relation("CycleCountCommittedBy")
  saleOrdersCreated      SaleOrder[]           @relation("SaleOrderCreatedBy")
  saleOrdersDispatched   SaleOrder[]           @relation("SaleOrderDispatchedBy")

  @@map("users")
}

model WarehousePermission {
  userId      String
  warehouseId String
  role        Role

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([userId, warehouseId])
  @@map("warehouse_permissions")
}

model Product {
  id        String   @id @default(uuid())
  sku       String   @unique
  barcode   String?
  name      String
  unit      String
  cost      Decimal  @default(0) @db.Decimal(14, 4)
  createdAt DateTime @default(now())

  stock              Stock[]
  movements          StockMovement[]
  transfers          Transfer[]
  purchaseOrderLines PurchaseOrderLine[]
  reservations       Reservation[]
  stockAlerts        StockAlert[]
  cycleCountLines    CycleCountLine[]
  saleOrderLines     SaleOrderLine[]

  @@map("products")
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  stock                Stock[]
  movements            StockMovement[]
  warehousePermissions WarehousePermission[]
  transfersFrom        Transfer[]            @relation("TransferFrom")
  transfersTo          Transfer[]            @relation("TransferTo")
  purchaseOrders       PurchaseOrder[]
  reservations         Reservation[]
  stockAlerts          StockAlert[]
  cycleCounts          CycleCount[]
  saleOrders           SaleOrder[]

  @@map("warehouses")
}

model Stock {
  productId        String
  warehouseId      String
  quantityOnHand   Decimal  @default(0) @db.Decimal(14, 4)
  quantityReserved Decimal  @default(0) @db.Decimal(14, 4)
  reorderPoint     Decimal? @db.Decimal(14, 4)
  version          Int      @default(0)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([productId, warehouseId])
  @@map("stock")
}

model StockAlert {
  id             String    @id @default(uuid())
  productId      String
  warehouseId    String
  quantityOnHand Decimal   @db.Decimal(14, 4)
  reorderPoint   Decimal   @db.Decimal(14, 4)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  resolvedAt     DateTime?

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([active])
  @@map("stock_alerts")
}

model StockMovement {
  id             String       @id @default(uuid())
  productId      String
  warehouseId    String
  type           MovementType
  quantity       Decimal      @db.Decimal(14, 4)
  reference      String?
  idempotencyKey String       @unique
  createdById    String
  createdAt      DateTime     @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])

  @@index([productId, warehouseId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Transfer {
  id              String         @id @default(uuid())
  productId       String
  fromWarehouseId String
  toWarehouseId   String
  quantity        Decimal        @db.Decimal(14, 4)
  status          TransferStatus @default(IN_TRANSIT)
  reference       String?
  idempotencyKey  String         @unique
  createdById     String
  receivedById    String?
  createdAt       DateTime       @default(now())
  receivedAt      DateTime?

  product       Product   @relation(fields: [productId], references: [id])
  fromWarehouse Warehouse @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse @relation("TransferTo", fields: [toWarehouseId], references: [id])
  createdBy     User      @relation("TransferCreatedBy", fields: [createdById], references: [id])
  receivedBy    User?     @relation("TransferReceivedBy", fields: [receivedById], references: [id])

  @@map("transfers")
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  taxId     String?  @unique
  email     String?
  phone     String?
  createdAt DateTime @default(now())

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  supplierId     String
  warehouseId    String
  status         PurchaseOrderStatus @default(PENDING)
  reference      String?
  idempotencyKey String              @unique
  createdById    String
  createdAt      DateTime            @default(now())

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  createdBy User                @relation(fields: [createdById], references: [id])
  lines     PurchaseOrderLine[]

  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id               String  @id @default(uuid())
  purchaseOrderId  String
  productId        String
  quantityOrdered  Decimal @db.Decimal(14, 4)
  quantityReceived Decimal @default(0) @db.Decimal(14, 4)
  unitCost         Decimal @db.Decimal(14, 4)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_lines")
}

enum SaleOrderStatus {
  PENDING
  DISPATCHED
  CANCELLED
}

enum CycleCountStatus {
  DRAFT
  COMMITTED
  CANCELLED
}

model SaleOrder {
  id             String          @id @default(uuid())
  warehouseId    String
  status         SaleOrderStatus @default(PENDING)
  reference      String?
  customerName   String?
  idempotencyKey String          @unique
  createdById    String
  dispatchedById String?
  createdAt      DateTime        @default(now())
  dispatchedAt   DateTime?

  warehouse    Warehouse      @relation(fields: [warehouseId], references: [id])
  createdBy    User           @relation("SaleOrderCreatedBy", fields: [createdById], references: [id])
  dispatchedBy User?          @relation("SaleOrderDispatchedBy", fields: [dispatchedById], references: [id])
  lines        SaleOrderLine[]

  @@map("sale_orders")
}

model SaleOrderLine {
  id          String  @id @default(uuid())
  saleOrderId String
  productId   String
  quantity    Decimal @db.Decimal(14, 4)
  unitPrice   Decimal @db.Decimal(14, 4)

  saleOrder SaleOrder @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@map("sale_order_lines")
}

model CycleCount {
  id            String           @id @default(uuid())
  warehouseId   String
  status        CycleCountStatus @default(DRAFT)
  reference     String?
  createdById   String
  committedById String?
  createdAt     DateTime         @default(now())
  committedAt   DateTime?

  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id])
  createdBy   User            @relation("CycleCountCreatedBy", fields: [createdById], references: [id])
  committedBy User?           @relation("CycleCountCommittedBy", fields: [committedById], references: [id])
  lines       CycleCountLine[]

  @@map("cycle_counts")
}

model CycleCountLine {
  id              String   @id @default(uuid())
  cycleCountId    String
  productId       String
  systemQuantity  Decimal  @db.Decimal(14, 4)
  countedQuantity Decimal? @db.Decimal(14, 4)
  difference      Decimal? @db.Decimal(14, 4)

  cycleCount CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([cycleCountId, productId])
  @@map("cycle_count_lines")
}

model Reservation {
  id             String            @id @default(uuid())
  productId      String
  warehouseId    String
  quantity       Decimal           @db.Decimal(14, 4)
  status         ReservationStatus @default(ACTIVE)
  reference      String?
  idempotencyKey String            @unique
  expiresAt      DateTime?
  createdById    String
  dispatchedById String?
  createdAt      DateTime          @default(now())
  dispatchedAt   DateTime?
  resolvedAt     DateTime?

  product      Product   @relation(fields: [productId], references: [id])
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  createdBy    User      @relation("ReservationCreatedBy", fields: [createdById], references: [id])
  dispatchedBy User?     @relation("ReservationDispatchedBy", fields: [dispatchedById], references: [id])

  @@map("reservations")
}
